# ──────────────────────────────────────────────
# EthioBanksHub — Environment Variables (example)
# ──────────────────────────────────────────────
# Copy this file to .env and adjust values.
#   cp .env.example .env

# ── PostgreSQL ────────────────────────────────
DATABASE_URL="postgresql://ethiobanks:ethiobanks@localhost:5432/ethiobankshub?schema=public"

# ── Redis ─────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379

# ── NestJS / API ──────────────────────────────
API_PORT=4000
API_PREFIX="api/v1"
NODE_ENV="development"

# ── Next.js / Web ─────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="EthioBanksHub"

# ── Security ──────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="change-me-to-a-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Session ───────────────────────────────────
SESSION_SECRET="change-me-to-a-random-session-secret"

# ── CORS ──────────────────────────────────────
CORS_ORIGINS="http://localhost:3000"
