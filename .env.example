# ──────────────────────────────────────────────
# EthioBanksHub — Environment Variables (example)
# ──────────────────────────────────────────────
# Copy this file to .env and adjust values.
#   cp .env.example .env

# ── PostgreSQL ────────────────────────────────
DATABASE_URL="postgresql://ethiobanks:ethiobanks@localhost:5432/ethiobankshub?schema=public"

# ── Redis ─────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379

# ── NestJS / API ──────────────────────────────
API_PORT=4000
API_PREFIX="api/v1"
NODE_ENV="development"

# ── Next.js / Web ─────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="EthioBanksHub"

# ── Security ──────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="change-me-to-a-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Session ───────────────────────────────────
SESSION_SECRET="change-me-to-a-random-session-secret"

# ── Google OAuth ─────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:4000/api/v1/auth/google/callback"

# ── Scraper ────────────────────────────────────
SCRAPER_ENABLED="true"
SCRAPER_ENABLED_BANKS="" # Empty = all, comma-separated for specific banks
SCRAPER_REQUEST_TIMEOUT="30000"
SCRAPER_SCHEDULE_HOUR="8"
SCRAPER_SCHEDULE_MINUTE="30"
SCRAPER_MAX_RETRIES="3"

# ── Telegram Notifications (for scrape failures) ─
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ── CORS ──────────────────────────────────────
CORS_ORIGINS="http://localhost:3000"
