# ──────────────────────────────────────────────
# EthioBanksHub — Production Environment File
# ──────────────────────────────────────────────
# Copy this to .env.production and fill in all values.
#
#   cp .env.example .env.production
#
# IMPORTANT: Never commit .env.production to version control!

# ══════════════════════════════════════════════
# REQUIRED: Generate secure secrets
# ══════════════════════════════════════════════
#
# Generate JWT_SECRET:
#   openssl rand -base64 64
#
# Generate CSRF_SECRET:
#   openssl rand -hex 32
#
# Generate REDIS_PASSWORD:
#   openssl rand -base64 32
#
# Generate POSTGRES_PASSWORD:
#   openssl rand -base64 32

# ══════════════════════════════════════════════
# Required — Database
# ══════════════════════════════════════════════
POSTGRES_USER=ethiobanks
POSTGRES_PASSWORD=change-me-to-a-random-password
POSTGRES_DB=ethiobankshub
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public"

# ══════════════════════════════════════════════
# Required — Redis
# ══════════════════════════════════════════════
REDIS_PASSWORD=change-me-to-a-random-password
REDIS_URL="redis://:${REDIS_PASSWORD}@redis:6379"
REDIS_HOST=redis
REDIS_PORT=6379

# ══════════════════════════════════════════════
# Required — API Configuration
# ══════════════════════════════════════════════
API_PORT=4000
API_PREFIX=api/v1
NODE_ENV=production

# ══════════════════════════════════════════════
# Required — JWT Authentication
# ══════════════════════════════════════════════
JWT_SECRET=change-me-to-a-random-secret-min-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CSRF_SECRET=change-me-to-a-random-hex-secret

# ══════════════════════════════════════════════
# Required — Session
# ══════════════════════════════════════════════
SESSION_SECRET=change-me-to-a-random-session-secret

# ══════════════════════════════════════════════
# Required — CORS (comma-separated origins)
# ══════════════════════════════════════════════
CORS_ORIGINS="https://ethiobankshub.com,https://www.ethiobankshub.com"

# ══════════════════════════════════════════════
# Optional — Google OAuth
# ══════════════════════════════════════════════
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="https://ethiobankshub.com/api/v1/auth/google/callback"

# ══════════════════════════════════════════════
# Optional — Scraper Configuration
# ══════════════════════════════════════════════
SCRAPER_ENABLED=true
SCRAPER_ENABLED_BANKS=""              # Empty = all banks
SCRAPER_REQUEST_TIMEOUT=30000
SCRAPER_SCHEDULE_HOUR=8               # Run at 8 AM
SCRAPER_SCHEDULE_MINUTE=30            # Run at :30
SCRAPER_MAX_RETRIES=3

# ══════════════════════════════════════════════
# Optional — Notifications
# ══════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=""                  # Telegram bot token for alerts
TELEGRAM_CHAT_ID=""                    # Telegram chat ID for alerts
SLACK_WEBHOOK_URL=""                   # Slack webhook for deploy notifications
DEPLOY_WEBHOOK_URL=""                  # Generic deploy webhook

# ══════════════════════════════════════════════
# Optional — Email (Mailgun / SMTP)
# ══════════════════════════════════════════════
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@ethiobankshub.com"

# ══════════════════════════════════════════════
# Optional — SMS (Africa's Talking / Twilio)
# ══════════════════════════════════════════════
SMS_PROVIDER=""                        # "africastalking" | "twilio" | ""
AFRICASTALKING_API_KEY=""
AFRICASTALKING_USERNAME=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ══════════════════════════════════════════════
# Optional — AWS (for backup S3 sync)
# ══════════════════════════════════════════════
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="ethiobankshub-backups"
AWS_DEFAULT_REGION="us-east-1"

# ══════════════════════════════════════════════
# Optional — Monitoring & Observability
# ══════════════════════════════════════════════
SENTRY_DSN=""                          # Sentry error tracking
DATADOG_API_KEY=""                     # Datadog APM
GRAFANA_CLOUD_API_KEY=""               # Grafana Cloud
PROMETHEUS_ENABLED=false               # Enable Prometheus metrics

# ══════════════════════════════════════════════
# Optional — Docker Scaling
# ══════════════════════════════════════════════
API_REPLICAS=2
WEB_REPLICAS=2

# ══════════════════════════════════════════════
# Optional — Backup
# ══════════════════════════════════════════════
BACKUP_RETENTION_DAYS=30

# ══════════════════════════════════════════════
# Optional — Domain & URLs
# ══════════════════════════════════════════════
DOMAIN=ethiobankshub.com
NEXT_PUBLIC_APP_URL="https://ethiobankshub.com"
NEXT_PUBLIC_API_URL="https://ethiobankshub.com/api/v1"
NEXT_PUBLIC_APP_NAME="EthioBanksHub"
NEXT_TELEMETRY_DISABLED=1
