{
  // Root tsconfig for IDE support and ESLint project resolution.
  // TypeScript type-checking is done per-package via `pnpm typecheck`.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "apps/api/src/**/*.ts",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "packages/shared/src/**/*.ts"
  ]
}
